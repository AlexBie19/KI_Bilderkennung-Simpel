<?xml version="1.0" encoding="utf-8"?>
<!--
  Android manifest for the Clothing Recognizer app.

  Required permissions:
    CAMERA            – Needed to access the device camera for photo capture.
    READ_EXTERNAL_STORAGE – Required on Android < 13 to read saved photos.
    READ_MEDIA_IMAGES – Required on Android 13+ to read image files.

  The camera feature declaration tells the Play Store that the app requires
  a camera; android:required="true" means the app will not be installed on
  devices without a camera.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Camera access permission (both Android ≤12 and Android ≥13) -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Storage read permission for Android 12 and below -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Granular media permission for Android 13+ (API 33+) -->
    <uses-permission
        android:name="android.permission.READ_MEDIA_IMAGES"
        android:minSdkVersion="33" />

    <!-- Declare that a camera hardware feature is required -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />

    <!-- Optional autofocus feature (available on most modern devices) -->
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false" />

    <application
        android:label="Clothing Recognizer"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:requestLegacyExternalStorage="false"
        android:enableOnBackInvokedCallback="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <!-- Specifies the initial Flutter route -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Flutter background services (required by flutter_plugin_android_lifecycle) -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <!-- Required by permission_handler on Android 12+ to explain permission rationale -->
    <queries>
        <intent>
            <action android:name="android.settings.APPLICATION_DETAILS_SETTINGS" />
        </intent>
    </queries>
</manifest>
